package toplevel

func Clamp(input int) int {
	return clamp(input)
}

func clamp(input int) int { // want `Place helper "clamp" below the top-level symbol "Clamp" that depends on it.`
	if input > internalLimit {
		return internalLimit
	}
	return input
}

// Invalid: unexported const before unexported func that uses it,
// where the func is consumed by an exported function
const internalLimit = 3 // want `Place constant "internalLimit" below the top-level symbol "clamp" that uses it.`
